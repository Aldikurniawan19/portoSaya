---
import { Image } from 'astro:assets';
import profileImage from '../assets/saya.png';
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale || 'id';
const t = getTranslations(lang);
---

<!-- 2. ABOUT SECTION -->
<section id="about" class="min-h-screen flex items-center bg-slate-50 relative py-24">
  <div class="max-w-6xl mx-auto px-6 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Foto Profil (Kiri, 5 kolom) -->
      <div class="lg:col-span-5 relative group flex justify-center" data-aos="fade-right">
        <!-- Decorative Frame Behind -->
        <div class="absolute -bottom-3 -right-3 w-full h-full bg-[#fdf2d5] rounded-[2rem] -z-10 transition-transform group-hover:translate-x-1 group-hover:translate-y-1"></div>

        <!-- Main Image Container -->
        <div class="relative rounded-[2rem] overflow-hidden shadow-xl aspect-[3/4] w-full max-w-[360px] bg-[#fbbf24] border border-slate-100/50">
          <Image
            src={profileImage}
            alt={t.about.altPhoto}
            class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-500"
            widths={[360, 720]}
            sizes="(max-width: 1024px) 360px, 360px"
          />
        </div>
      </div>

      <!-- Data Diri (Kanan, 7 kolom) -->
      <div class="lg:col-span-7 space-y-6 flex flex-col justify-center">
        <!-- Title Badge Row -->
        <div class="space-y-4">
          <div class="flex flex-wrap items-center gap-3 text-3xl md:text-4xl font-extrabold text-secondary tracking-tight">
            <span>{t.about.badge}</span>
            <span class="bg-[#3b82f6] text-white px-4 py-1.5 rounded-xl text-2xl md:text-3xl font-extrabold tracking-wide uppercase">{t.about.name}</span>
          </div>
          <div class="bg-[#10b981]/25 text-[#065f46] px-4 py-2 rounded-xl text-sm md:text-base font-black tracking-wider w-fit border border-[#10b981]/30">
            {t.about.role}
          </div>
        </div>

        <!-- Bordered Paragraphs -->
        <div class="border-l-4 border-indigo-500 pl-6 space-y-4">
          <p id="about-text-1" class="text-slate-600 leading-relaxed text-base font-medium" data-text={t.about.paragraph1}>
            {t.about.paragraph1}
          </p>
          <p id="about-text-2" class="text-slate-600 leading-relaxed text-base font-medium" data-text={t.about.paragraph2}>
            {t.about.paragraph2}
          </p>
        </div>

        <!-- Action Button -->
        <div class="pt-2">
          <a href="#" class="px-6 py-3.5 bg-slate-900 text-white rounded-full font-bold hover:bg-slate-800 hover:shadow-lg shadow-md transition-all flex items-center gap-2 w-fit">
            <i data-lucide="download" class="w-4 h-4"></i>
            {t.about.downloadCV}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initAboutTypewriter() {
    const p1 = document.getElementById("about-text-1");
    const p2 = document.getElementById("about-text-2");
    if (!p1 || !p2) return;

    // Grab correct text content from data attributes or innerText
    const text1 = p1.getAttribute("data-text") || p1.innerText.trim();
    const text2 = p2.getAttribute("data-text") || p2.innerText.trim();

    // Ensure data attribute contains the clean text
    p1.setAttribute("data-text", text1);
    p2.setAttribute("data-text", text2);

    // Empty contents initially
    p1.innerHTML = "";
    p2.innerHTML = "";

    // Create a blinking cursor element
    const cursor = document.createElement("span");
    cursor.className = "inline-block w-[2px] h-[1em] bg-indigo-500 ml-1 align-middle animate-pulse";
    cursor.style.animationDuration = "0.8s";

    let hasStarted = false;

    // Setup intersection observer
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !hasStarted) {
          hasStarted = true;
          startTyping();
          observer.disconnect();
        }
      });
    }, { rootMargin: "-10% 0px -15% 0px", threshold: 0.1 });

    const aboutSection = document.getElementById("about");
    if (aboutSection) {
      observer.observe(aboutSection);
    }

    function startTyping() {
      let index1 = 0;
      let index2 = 0;
      const speed = 20; // Typing speed in ms per character (fast and smooth)

      function typeP1() {
        if (index1 < text1.length) {
          p1.innerHTML = text1.substring(0, index1 + 1);
          p1.appendChild(cursor);
          index1++;
          setTimeout(typeP1, speed);
        } else {
          // Remove cursor from p1
          if (p1.contains(cursor)) {
            p1.removeChild(cursor);
          }
          // Start p2
          setTimeout(typeP2, 200);
        }
      }

      function typeP2() {
        if (index2 < text2.length) {
          p2.innerHTML = text2.substring(0, index2 + 1);
          p2.appendChild(cursor);
          index2++;
          setTimeout(typeP2, speed);
        } else {
          // Keep cursor blinking for 2 seconds after completion, then remove
          setTimeout(() => {
            if (p2.contains(cursor)) {
              p2.removeChild(cursor);
            }
          }, 2000);
        }
      }

      typeP1();
    }
  }

  // Load typewriter
  initAboutTypewriter();
  // Support Astro SPA transition events
  document.addEventListener("astro:page-load", initAboutTypewriter);
</script>
