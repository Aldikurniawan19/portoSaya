---
import { Image } from 'astro:assets';
import imgHero from '../assets/imgHero.png';
---

<!-- 1. HOME SECTION -->
<section id="home" class="relative min-h-screen flex items-center pt-20 overflow-hidden">
  <!-- Background Grid Pattern -->
  <div class="absolute inset-0 bg-grid-pattern bg-grid -z-10"></div>

  <div class="max-w-7xl mx-auto px-6 w-full grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
    <!-- Left Content: Typography Focused -->
    <div class="space-y-6 order-2 lg:order-1 fade-in-up">
      <span class="text-xs font-bold uppercase tracking-widest text-slate-400">HALO, SAYA</span>

      <h1 class="text-5xl lg:text-6xl font-extrabold text-secondary leading-[1.1] tracking-tight">
        Aldi <br />
        <span class="text-blue-600">Kurniawan</span><span class="text-secondary">.</span>
      </h1>

      <p class="text-lg font-bold text-secondary">Fullstack Developer</p>

      <div class="flex items-center gap-4 text-slate-400">
        <a href="https://github.com/Aldikurniawan19" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hover:text-slate-900 transition-all duration-300 transform hover:scale-110 inline-block">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
        </a>
        <a href="https://www.instagram.com/aldii_kurniawannnn?igsh=MWJ4c2I3dmIyM3gwdQ==" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="hover:text-[#E1306C] transition-all duration-300 transform hover:scale-110 inline-block">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
        </a>
        <a href="#" aria-label="LinkedIn" class="hover:text-[#0077B5] transition-all duration-300 transform hover:scale-110 inline-block">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect width="4" height="12" x="2" y="9"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      </div>

      <p class="text-base text-slate-500 max-w-md leading-relaxed">
        Membangun aplikasi web yang fungsional, interaktif, dan berpusat pada pengalaman pengguna.
      </p>

      <div class="flex flex-wrap gap-4 pt-2">
        <a href="#portfolio" class="px-6 py-3.5 bg-violet-600 text-white rounded-full font-bold hover:bg-violet-700 hover:shadow-lg hover:shadow-violet-500/20 transition-all flex items-center gap-2">
          <i data-lucide="briefcase" class="w-4 h-4"></i>
          Lihat Proyek
        </a>
        <a href="#contact" class="px-6 py-3.5 bg-white border border-slate-200 text-slate-700 rounded-full font-bold hover:border-primary hover:text-primary hover:shadow-sm transition-all flex items-center gap-2">
          <i data-lucide="mail" class="w-4 h-4"></i>
          Hubungi Saya
        </a>
      </div>
    </div>

    <!-- Right Content: Hero Image with Abstract Blue Background -->
    <div class="order-1 lg:order-2 relative flex justify-center" data-aos="zoom-in" data-aos-delay="200">
      <!-- Background Glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-indigo-500/10 rounded-full blur-3xl -z-10"></div>

      <!-- Main Image Container (Lifted up slightly) -->
      <div class="relative w-full max-w-[360px] aspect-[4/5] flex items-end justify-center overflow-visible -translate-y-6 lg:-translate-y-10">
        <!-- Abstract Oval Background Shape (Blue organic shape) -->
        <div class="absolute bottom-4 left-1/2 -translate-x-1/2 w-[220px] h-[280px] bg-[#3b82f6] rounded-[60%_40%_30%_70%_/_60%_30%_70%_40%] rotate-[6deg] -z-10 shadow-lg shadow-blue-500/15"></div>

        <!-- Person Image Cutout -->
        <Image
          src={imgHero}
          alt="Aldi Kurniawan"
          class="w-full h-auto object-contain z-10 drop-shadow-2xl"
          widths={[400, 800]}
          sizes="(max-width: 1024px) 100vw, 360px"
        />
      </div>
    </div>
  </div>
</section>
