---
import { Image } from 'astro:assets';
import projectImage from '../assets/project_portfolio_1782149727982.png';
---

<!-- 5. PORTFOLIO SECTION (KARYA TERBAIK) -->
<section id="portfolio" class="py-24 bg-white relative overflow-hidden">
  <div class="absolute inset-0 bg-grid-pattern bg-grid opacity-30 -z-10"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-indigo-50/40 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-6xl mx-auto px-6 w-full">
    <!-- Section Header -->
    <div class="text-center mb-16 scroll-reveal">
      <h2 class="text-sm font-bold text-primary uppercase tracking-widest mb-2">Karya Terbaik</h2>
      <h3 class="text-3xl md:text-4xl font-bold text-secondary">Karya Terbaik & Implementasi Skills</h3>
      <p class="text-slate-500 mt-4 max-w-lg mx-auto">Berikut adalah proyek terbaik yang mengintegrasikan seluruh keahlian saya dalam pengembangan web modern.</p>
    </div>

    <!-- Project Showcase Container -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
      <!-- Left Column: Browser Mockup -->
      <div class="lg:col-span-6 relative group scroll-reveal-left">
        <div class="absolute -inset-2 bg-gradient-to-r from-primary to-indigo-600 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition duration-1000 group-hover:duration-200"></div>

        <div class="relative bg-slate-900 rounded-xl shadow-2xl overflow-hidden border border-slate-700/80 transition-transform duration-500 group-hover:-translate-y-2">
          <!-- Browser Window Header -->
          <div class="bg-slate-800 px-4 py-3 flex items-center gap-2 border-b border-slate-700/80">
            <div class="w-3 h-3 rounded-full bg-red-500"></div>
            <div class="w-3 h-3 rounded-full bg-yellow-500"></div>
            <div class="w-3 h-3 rounded-full bg-green-500"></div>
            <div class="ml-4 text-[10px] text-slate-400 font-mono flex items-center gap-1.5 bg-slate-900 px-3 py-0.5 rounded-md border border-slate-700">
              <i data-lucide="globe" class="w-3 h-3"></i>
              alldev.portfolio.io
            </div>
          </div>
          <!-- Image Wrapper -->
          <div class="overflow-hidden aspect-video relative bg-slate-950 flex items-center justify-center">
            <Image
              src={projectImage}
              alt="All Dev Portfolio Project"
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              widths={[600, 1200]}
              sizes="(max-width: 1024px) 100vw, 50vw"
            />
          </div>
        </div>
      </div>

      <!-- Right Column: Project Information -->
      <div class="lg:col-span-6 space-y-6 scroll-reveal-right">
        <div class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1 bg-indigo-50 text-primary rounded-full border border-indigo-100">
          <span class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></span>
          Karya Unggulan
        </div>
        <h4 class="text-3xl font-extrabold text-secondary tracking-tight">All.Dev - Modern Developer Portfolio</h4>
        <p class="text-slate-600 leading-relaxed">
          Platform website portofolio interaktif yang dirancang dengan estetika visual tinggi, tata letak modern responsif, serta penekanan pada aspek SEO dan performa. Proyek ini memvisualisasikan data diri, keterampilan teknologi, dan riwayat profesional secara dinamis.
        </p>

        <!-- Key Features List -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-primary shrink-0">
              <i data-lucide="layout" class="w-4 h-4"></i>
            </div>
            <div>
              <h5 class="text-sm font-bold text-secondary">Desain Responsif</h5>
              <p class="text-xs text-slate-500">Optimal di hp, tablet, laptop.</p>
            </div>
          </div>

          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-primary shrink-0">
              <i data-lucide="code-2" class="w-4 h-4"></i>
            </div>
            <div>
              <h5 class="text-sm font-bold text-secondary">HTML Semantik</h5>
              <p class="text-xs text-slate-500">Struktur ramah SEO & aksesibel.</p>
            </div>
          </div>

          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-primary shrink-0">
              <i data-lucide="zap" class="w-4 h-4"></i>
            </div>
            <div>
              <h5 class="text-sm font-bold text-secondary">Active Scroll Spy</h5>
              <p class="text-xs text-slate-500">Deteksi section otomatis saat scroll.</p>
            </div>
          </div>

          <div class="flex gap-3">
            <div class="w-8 h-8 rounded-lg bg-indigo-50 flex items-center justify-center text-primary shrink-0">
              <i data-lucide="palette" class="w-4 h-4"></i>
            </div>
            <div>
              <h5 class="text-sm font-bold text-secondary">Utility-First CSS</h5>
              <p class="text-xs text-slate-500">Styling cepat & rapi dengan Tailwind.</p>
            </div>
          </div>
        </div>

        <!-- Tech Stack Badges -->
        <div class="pt-4 border-t border-slate-100">
          <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-2">Teknologi yang Digunakan</p>
          <div class="flex flex-wrap gap-2">
            <span class="px-2.5 py-1 bg-slate-100 text-slate-600 rounded-md text-xs font-semibold">HTML5</span>
            <span class="px-2.5 py-1 bg-slate-100 text-slate-600 rounded-md text-xs font-semibold">CSS3</span>
            <span class="px-2.5 py-1 bg-slate-100 text-slate-600 rounded-md text-xs font-semibold">JavaScript (ES6+)</span>
            <span class="px-2.5 py-1 bg-indigo-50 text-primary rounded-md text-xs font-semibold">Tailwind CSS</span>
            <span class="px-2.5 py-1 bg-purple-50 text-purple-600 rounded-md text-xs font-semibold">Lucide Icons</span>
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-wrap gap-4 pt-2">
          <a href="#home" class="px-6 py-3 bg-secondary text-white rounded-lg text-sm font-bold hover:bg-primary hover:shadow-lg hover:shadow-indigo-500/20 transition-all flex items-center gap-2">
            <i data-lucide="external-link" class="w-4 h-4"></i>
            Lihat Demo Live
          </a>
          <a href="https://github.com/Aldikurniawan19" target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-white border border-slate-200 text-slate-700 rounded-lg text-sm font-bold hover:border-primary hover:text-primary transition-all flex items-center gap-2">
            <i data-lucide="github" class="w-4 h-4"></i>
            Source Code
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
