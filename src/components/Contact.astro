---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale || 'id';
const t = getTranslations(lang);
---

<!-- 5. CONTACT SECTION (HUBUNGI SAYA) -->
<section id="contact" class="py-24 bg-slate-50 relative overflow-hidden text-slate-600 border-t border-slate-100">
  <div class="absolute inset-0 bg-grid-pattern bg-grid opacity-30 -z-10"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-6xl mx-auto px-6 w-full">
    <!-- Section Header -->
    <div class="text-center mb-16" data-aos="fade-up">
      <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1 bg-primary/10 text-primary rounded-full border border-primary/20 mb-3">
        {t.contact.badge}
      </span>
      <h3 class="text-3xl md:text-4xl font-bold text-secondary">{t.contact.title}</h3>
      <p class="text-slate-500 mt-4 max-w-lg mx-auto">{t.contact.description}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-start">
      <!-- Left Column: Contact Cards -->
      <div class="lg:col-span-5 space-y-6" data-aos="fade-right">
        <h4 class="text-xl font-bold text-secondary mb-4">{t.contact.infoTitle}</h4>

        <!-- Card 1: Email -->
        <a href="mailto:aldikurniawan19@gmail.com" class="flex items-center gap-4 p-5 bg-white border border-slate-100 rounded-2xl hover:border-primary/30 hover:shadow-lg hover:shadow-indigo-500/5 transition-all duration-300 group shadow-sm">
          <div class="w-12 h-12 bg-primary/10 text-primary rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
          </div>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider">{t.contact.sendEmail}</p>
            <p class="text-sm font-bold text-secondary mt-0.5">aldikurniawan19@gmail.com</p>
          </div>
        </a>

        <!-- Card 2: Instagram -->
        <a href="https://www.instagram.com/aldii_kurniawannnn?igsh=MWJ4c2I3dmIyM3gwdQ==" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 bg-white border border-slate-100 rounded-2xl hover:border-primary/30 hover:shadow-lg hover:shadow-indigo-500/5 transition-all duration-300 group shadow-sm">
          <div class="w-12 h-12 bg-[#E1306C]/10 text-[#E1306C] rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line></svg>
          </div>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider">{t.contact.instagram}</p>
            <p class="text-sm font-bold text-secondary mt-0.5">@aldii_kurniawannnn</p>
          </div>
        </a>

        <!-- Card 3: GitHub -->
        <a href="https://github.com/Aldikurniawan19" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 bg-white border border-slate-100 rounded-2xl hover:border-primary/30 hover:shadow-lg hover:shadow-indigo-500/5 transition-all duration-300 group shadow-sm">
          <div class="w-12 h-12 bg-slate-100 text-slate-800 rounded-xl flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
          </div>
          <div>
            <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider">{t.contact.github}</p>
            <p class="text-sm font-bold text-secondary mt-0.5">Aldikurniawan19</p>
          </div>
        </a>
      </div>

      <!-- Right Column: Contact Form -->
      <div class="lg:col-span-7 bg-white border border-slate-100 rounded-2xl p-8 shadow-sm hover:border-primary/30 transition-all duration-300" data-aos="fade-left">
        <h4 class="text-xl font-bold text-secondary mb-6">{t.contact.formTitle}</h4>
        <form id="contact-form" action="#" method="POST" class="space-y-6" data-success-msg={t.contact.successAlert}>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="name" class="block text-xs font-bold text-slate-500 uppercase mb-2">{t.contact.labelName}</label>
              <input type="text" id="name" name="name" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all placeholder-slate-400" placeholder="John Doe" />
            </div>
            <div>
              <label for="email" class="block text-xs font-bold text-slate-500 uppercase mb-2">{t.contact.labelEmail}</label>
              <input type="email" id="email" name="email" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all placeholder-slate-400" placeholder="johndoe@example.com" />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-xs font-bold text-slate-500 uppercase mb-2">{t.contact.labelSubject}</label>
            <input type="text" id="subject" name="subject" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all placeholder-slate-400" placeholder={t.contact.placeholderSubject} />
          </div>

          <div>
            <label for="message" class="block text-xs font-bold text-slate-500 uppercase mb-2">{t.contact.labelMessage}</label>
            <textarea id="message" name="message" rows="5" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-sm text-slate-700 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary transition-all placeholder-slate-400 resize-none" placeholder={t.contact.placeholderMessage}></textarea>
          </div>

          <button type="submit" class="w-full py-4 bg-primary text-white rounded-xl text-sm font-bold hover:bg-indigo-500 hover:shadow-lg hover:shadow-indigo-500/20 transition-all flex items-center justify-center gap-2 group">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-hover:translate-x-1 group-hover:-translate-y-1 transition-transform"><line x1="22" x2="11" y1="2" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
            {t.contact.buttonSend}
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById("contact-form");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const successMsg = form.getAttribute("data-success-msg") || "Pesan Anda berhasil dikirim! (Demo)";
    alert(successMsg);
  });
</script>
