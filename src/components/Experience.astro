---
import { getTranslations } from '../i18n/translations';

const lang = Astro.currentLocale || 'id';
const t = getTranslations(lang);

const meta = [
  {
    typeColor: "bg-primary/10 text-primary border-primary/20",
    icon: "building-2",
    tags: ["HTML5", "CSS3", "JavaScript", "Tailwind CSS"],
  },
  {
    typeColor: "bg-emerald-500/10 text-emerald-600 border-emerald-500/20",
    icon: "building-2",
    tags: ["Web Admin", "MySQL", "Troubleshooting"],
  },
  {
    typeColor: "bg-amber-500/10 text-amber-600 border-amber-500/20",
    icon: "user",
    tags: ["Responsive Web", "UI/UX Design", "HTML & CSS"],
  },
];

const experiences = t.experience.items.map((item, index) => ({
  ...item,
  ...meta[index],
}));
---

<!-- 4. WORK EXPERIENCE SECTION -->
<section id="experience" class="py-24 bg-slate-50 relative overflow-hidden text-slate-600">
  <div class="absolute inset-0 bg-grid-pattern bg-grid opacity-30 -z-10"></div>
  <div class="absolute top-1/3 left-1/4 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl -z-10"></div>
  <div class="absolute bottom-1/3 right-1/4 w-[500px] h-[500px] bg-purple-500/5 rounded-full blur-3xl -z-10"></div>

  <div class="max-w-4xl mx-auto px-6 w-full">
    <!-- Section Header -->
    <div class="text-center mb-20" data-aos="fade-up">
      <h2 class="text-sm font-bold text-primary uppercase tracking-widest mb-2">{t.experience.title}</h2>
      <h3 class="text-3xl md:text-4xl font-bold text-secondary">{t.experience.subtitle}</h3>
      <p class="text-slate-500 mt-4 max-w-lg mx-auto">{t.experience.description}</p>
    </div>

    <!-- Timeline Container -->
    <div class="relative border-l border-slate-200 ml-4 md:ml-6 pl-8 md:pl-12 space-y-12">
      {experiences.map((exp, index) => (
        <div class="relative group timeline-item" data-aos="fade-up" data-aos-delay={index * 100}>
          <!-- Timeline Dot -->
          <div class="timeline-dot absolute -left-[41px] md:-left-[57px] top-1.5 w-6 h-6 bg-white rounded-full border-4 border-slate-200 group-hover:border-primary group-hover:shadow-[0_0_12px_rgba(79,70,229,0.2)] transition-all duration-300 flex items-center justify-center">
            <div class="timeline-dot-inner w-1.5 h-1.5 bg-slate-300 group-hover:bg-primary rounded-full transition-colors"></div>
          </div>

          <!-- Content Card -->
          <div class="experience-card bg-white border border-slate-100 rounded-2xl p-6 md:p-8 hover:border-primary/30 hover:shadow-xl hover:shadow-indigo-500/5 transition-all duration-300 transform hover:-translate-y-1 shadow-sm">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mb-4">
              <div>
                <span class={`inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1 rounded-full border mb-3 ${exp.typeColor}`}>
                  {exp.type}
                </span>
                <h4 class="text-xl font-bold text-secondary">{exp.title}</h4>
              </div>
              <span class="text-xs font-bold text-slate-500 md:text-right bg-slate-50 border border-slate-200 px-3 py-1 rounded-full w-fit">
                {exp.period}
              </span>
            </div>

            <div class="flex items-center gap-2 text-sm text-primary font-semibold mb-4">
              <i data-lucide={exp.icon} class="w-4 h-4"></i>
              <span>{exp.company}</span>
            </div>

            <p class="text-slate-600 text-sm leading-relaxed mb-6">{exp.description}</p>

            <div class="flex flex-wrap gap-2">
              {exp.tags.map((tag) => (
                <span class="text-xs font-medium px-2.5 py-1 bg-slate-50 border border-slate-200 rounded-md text-slate-600">{tag}</span>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style is:global>
  /* Active timeline dot styles when card is in viewport */
  .timeline-item.active .timeline-dot {
    border-color: #4f46e5 !important;
    box-shadow: 0 0 12px rgba(79, 70, 229, 0.4) !important;
  }
  .timeline-item.active .timeline-dot-inner {
    background-color: #4f46e5 !important;
  }

  /* Active card styles when card is in viewport */
  .timeline-item.active .experience-card {
    border-color: rgba(79, 70, 229, 0.3) !important;
    box-shadow: 0 20px 25px -5px rgba(99, 102, 241, 0.08), 0 10px 10px -5px rgba(99, 102, 241, 0.08) !important;
    transform: translateY(-6px) !important;
  }
</style>

<script>
  function initObserver() {
    const observerOptions = {
      root: null,
      rootMargin: "-25% 0px -25% 0px", // Trigger when the item is around the middle of the screen
      threshold: 0.1,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("active");
        } else {
          entry.target.classList.remove("active");
        }
      });
    }, observerOptions);

    document.querySelectorAll(".timeline-item").forEach((item) => {
      observer.observe(item);
    });
  }

  // Initialize on load
  initObserver();
  // Also run on page transitions if standard SPA or dynamic loads are used
  document.addEventListener("astro:page-load", initObserver);
</script>
